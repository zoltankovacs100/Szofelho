rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // A 'sessions' gyűjtemény
    match /sessions/{sessionId} {
      // Bárki olvashatja a session adatokat
      allow read: if true;

      // Session-t létrehozni, módosítani, törölni csak
      // authentikált felhasználó tud (azaz az admin).
      allow write: if request.auth != null;
    }

    // A szavak al-gyűjteménye
    match /sessions/{sessionId}/words/{wordId} {
      // Bárki olvashatja a szavakat
      allow read: if true;

      // Bárki létrehozhat új szót (ehhez nem kell bejelentkezés)
      allow create: if true;

      // Módosítani és törölni nem lehet
      allow update, delete: if false;
    }
  }
}
